# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

CHAT_RATE_LIMIT_MAX_TOKENS=50000
CHAT_RATE_LIMIT_WINDOW_MS=360000
LLM_MAX_CONCURRENT=3

# Monitoring — Discord webhook alert when DB size approaches Supabase free tier (500 MB)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token
SUPABASE_DB_SIZE_WARN_MB=400
SUPABASE_DB_SIZE_CRITICAL_MB=480
MONITOR_SECRET=your-random-secret-here