# - Vercel: VERCEL_URL (httpsプロトコル付きで自動変換)

CHAT_RATE_LIMIT_MAX_TOKENS=50000
CHAT_RATE_LIMIT_WINDOW_MS=360000
LLM_MAX_CONCURRENT=3