{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/log/layout,_N_T_/log/new/layout,_N_T_/log/new/page,_N_T_/log/new"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/log/new/__PAGE__",
    "/log/new",
    "/log",
    "/_index",
    "/_head"
  ]
}