{
	"$schema": "node_modules/wrangler/config-schema.json",
	"main": "worker.ts",
	"name": "lustra-mvp-ui",
	"compatibility_date": "2026-03-13",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"assets": {
		"directory": ".open-next/assets",
		"binding": "ASSETS"
	},
	"services": [
		{
			// Self-reference service binding, the service name must match the worker name
			// see https://opennext.js.org/cloudflare/caching
			"binding": "WORKER_SELF_REFERENCE",
			"service": "lustra-mvp-ui"
		}
	],
	"images": {
		// Enable image optimization
		// see https://opennext.js.org/cloudflare/howtos/image
		"binding": "IMAGES"
	},
	// ── ユーザー固有HTMLキャッシュ用 KV ──────────────────────────────────────
	// 初回セットアップ時に以下を実行して id を取得してから差し替えること:
	//   npx wrangler kv namespace create "HTML_CACHE"
	//   npx wrangler kv namespace create "HTML_CACHE" --preview
	"kv_namespaces": [
		{
			"binding": "HTML_CACHE",
			"id": "3194659df99e40e9a561e94fe57755b0",
			"preview_id": "ec9c007488be4477a1de8bb751815a94"
		}
	],
	// ── 分析ジョブのための Cloudflare Queues ──────────────────────────────────
	// Queue作成: npx wrangler queues create analysis-jobs
	"queues": {
		"producers": [
			{
				"queue": "analysis-jobs",
				"binding": "ANALYSIS_QUEUE"
			}
		],
		"consumers": [
			{
				"queue": "analysis-jobs",
				"max_batch_size": 10,
				"max_batch_timeout": 30,
				"max_retries": 3,
				"dead_letter_queue": "analysis-jobs-dead-letter"
			}
		]
	},
	// Smart placement: automatically routes Worker invocations to the CF region nearest
	// to the origin database, minimizing round-trip latency between the Worker and Supabase.
	// Set your Supabase project region to ap-northeast-1 (Tokyo) or whichever region is
	// closest to your primary user base for best results.
	"placement": {
		"mode": "smart"
	},
	// ── Production LLM environment defaults ────────────────────────────────
	// These are used as the default LLM configuration in production.
	// In production, user-managed LLM settings are disabled for security.
	// For production deployments, set LLM_API_KEY as a secret:
	//   npx wrangler secret put LLM_API_KEY
	"vars": {
		"APP_ENV": "production",
		"LLM_PROVIDER": "openai",
		"LLM_TYPE": "gpt",
		"LLM_MODEL": "gpt-4.1-mini",
		"LLM_BASE_URL": "https://api.openai.com/v1"
	},
	// ── Scheduled handlers for daily batch analysis ────────────────────────
	// Daily analysis batch runs at 00:00 UTC every day
	"triggers": {
		"crons": [
			"0 0 * * *"
		]
	}
}
